{% if section.blocks.size > 0 %}
<div class="announcement-bar color-{{ section.settings.color_scheme }} gradient" role="region" aria-label="Announcement">
  <div class="announcement-bar__wrap">
    {% if section.blocks.size == 1 %}
      {% assign msg = section.blocks.first %}
      <p class="announcement-bar__message h5">
        {% if msg.settings.link != blank %}
          <a href="{{ msg.settings.link }}" class="full-unstyled-link">{{ msg.settings.text | escape }}</a>
        {% else %}
          {{ msg.settings.text | escape }}
        {% endif %}
      </p>
    {% else %}
      <div class="announcement-bar__slider" id="tsqAnnouncementSlider">
        {% for block in section.blocks %}
          <p class="announcement-bar__message h5 {% if forloop.first %}active{% endif %}">
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="full-unstyled-link">{{ block.settings.text | escape }}</a>
            {% else %}
              {{ block.settings.text | escape }}
            {% endif %}
          </p>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>
<style>
.announcement-bar__wrap { max-width: 100%; padding: 8px 24px; text-align: center; overflow: hidden; }
.announcement-bar__slider { position: relative; }
.announcement-bar__message { margin: 0; display: none; }
.announcement-bar__message.active { display: block; }
</style>
<script>
(function() {
  var msgs = document.querySelectorAll('#tsqAnnouncementSlider .announcement-bar__message');
  if (msgs.length < 2) return;
  var i = 0;
  setInterval(function() {
    msgs[i].classList.remove('active');
    i = (i + 1) % msgs.length;
    msgs[i].classList.add('active');
  }, 4000);
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        { "type": "text", "id": "text", "default": "Announcement", "label": "Text" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "settings": [
    { "type": "select", "id": "color_scheme", "options": [{"value":"accent-1","label":"Accent 1"},{"value":"background-1","label":"Background 1"}], "default": "accent-1", "label": "Color scheme" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
