{% comment %} TSQ Shop by Collection — v3 {% endcomment %}
{% comment %}
  Lifestyle categories: oud, fresh-aquatic, oriental-amber, floral-rose, gourmand-sweet
  Product-image categories: masculine, feminine, unisex, all-decants
{% endcomment %}

{% assign lifestyle_handles = "oud,fresh-aquatic,oriental-amber,floral-rose,gourmand-sweet" | split: "," %}

