<style>
.tsq-cg-section {
  background: var(--tsq-pearl, #FAF8F3);
  padding: 64px 20px;
}
.tsq-section-head { text-align: center; margin-bottom: 40px; }
.tsq-cg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  max-width: 1100px;
  margin: 0 auto;
}
@media(max-width: 768px) { .tsq-cg-grid { grid-template-columns: repeat(2, 1fr); } }
@media(max-width: 480px) { .tsq-cg-grid { grid-template-columns: 1fr 1fr; gap: 8px; } }

.tsq-cg-tile {
  position: relative; height: 280px;
  border-radius: 3px; overflow: hidden;
  display: block; text-decoration: none; cursor: pointer;
}
@media(max-width: 480px) { .tsq-cg-tile { height: 170px; } }

.tsq-cg-bg {
  position: absolute; inset: 0;
  background-image: var(--tile-bg, linear-gradient(135deg, var(--tsq-champagne, #EFE5D2), var(--tsq-stone, #D8C9B6)));
  background-size: cover; background-position: center;
  transition: transform 0.5s cubic-bezier(0.25,0.8,0.25,1);
}
.tsq-cg-tile:hover .tsq-cg-bg { transform: scale(1.06); }

.tsq-cg-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(13,13,13,0.75) 100%);
  transition: background 0.3s ease;
}
.tsq-cg-tile:hover .tsq-cg-overlay {
  background: linear-gradient(180deg, rgba(0,0,0,0.04) 0%, rgba(13,13,13,0.55) 100%);
}
.tsq-cg-content {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: flex-start; justify-content: flex-end;
  padding: 18px 20px;
}
.tsq-cg-label {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px; color: #FAF7F2 !important;
  font-weight: 500; display: block;
  text-shadow: 0 2px 10px rgba(0,0,0,0.6);
  margin-bottom: 4px;
}
@media(max-width: 480px) { .tsq-cg-label { font-size: 16px; } }
.tsq-cg-cta {
  font-family: 'Manrope', sans-serif;
  font-size: 11px; color: #C9A96E !important; letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0; transform: translateY(6px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.tsq-cg-tile:hover .tsq-cg-cta { opacity: 1; transform: translateY(0); }
</style>

{% schema %}
{
  "name": "TSQ Collections Grid",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section title", "default": "Find Your Scent" }
  ],
  "presets": [{ "name": "TSQ Collections Grid" }]
}
{% endschema %}
