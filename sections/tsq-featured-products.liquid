{%- assign feat_collection = collections['all'] -%}
<div style="background:#0D0D0D;padding:72px 20px;">
  <div style="max-width:1280px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:48px;">
      <p style="font-family:'Manrope',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:#C9A96E;margin:0 0 12px;">Handpicked</p>
      <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(28px,4vw,48px);font-weight:400;font-style:italic;color:#FFFFFF;margin:0 0 12px;">Decants Worth Discovering</h2>
      <p style="font-family:'Lora',serif;font-size:16px;color:rgba(250,247,242,0.62);max-width:520px;margin:0 auto;">A curated selection from the world's most respected Arabian fragrance houses.</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:20px;">
      {%- for product in feat_collection.products limit: 8 -%}
        <a href="{{ product.url }}" style="text-decoration:none;display:block;background:#1A1410;border:1px solid rgba(201,169,110,0.15);transition:border-color 0.3s,transform 0.3s;" onmouseover="this.style.borderColor='rgba(201,169,110,0.4)';this.style.transform='translateY(-4px)'" onmouseout="this.style.borderColor='rgba(201,169,110,0.15)';this.style.transform='translateY(0)'">
          <div style="aspect-ratio:1/1;background:#111009;display:flex;align-items:center;justify-content:center;overflow:hidden;">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" style="width:100%;height:100%;object-fit:contain;padding:16px;" loading="lazy">
            {%- else -%}
              <span style="font-family:'Cormorant Garamond',serif;font-size:48px;color:rgba(201,169,110,0.12);">SQ</span>
            {%- endif -%}
          </div>
          <div style="padding:16px;">
            <p style="font-family:'Manrope',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#C9A96E;margin:0 0 4px;">{{ product.vendor }}</p>
            <h3 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:16px;font-weight:400;color:#FFFFFF;margin:0 0 8px;line-height:1.3;">{{ product.title }}</h3>
            <p style="font-family:'Manrope',sans-serif;font-size:14px;font-weight:700;color:#C9A96E;margin:0;">From {{ product.price_min | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="/collections/all" style="display:inline-block;background:#C9A96E;color:#0D0D0D;font-family:'Manrope',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;padding:15px 40px;text-decoration:none;">View All Decants</a>
    </div>
  </div>
</div>

{% schema %}
{ "name": "TSQ Featured Products", "tag": "div", "presets": [{ "name": "TSQ Featured Products" }] }
{% endschema %}