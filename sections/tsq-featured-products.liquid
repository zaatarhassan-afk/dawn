{% liquid
  assign featured_collection = collections[section.settings.collection]
  if featured_collection == blank or featured_collection.products.size == 0
    assign featured_collection = collections['all']
  endif
  assign max_products = section.settings.max_products | default: 8
%}

<section class="tsq-featured-products tsq-section">
  <div class="tsq-section__inner">
    <span class="tsq-eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="tsq-section-title">{{ section.settings.title }}</h2>
    <div class="tsq-divider"></div>

    <div class="tsq-products-grid">
      {% for product in featured_collection.products limit: max_products %}
        <div class="tsq-product-card tsq-animate-in" style="animation-delay: {{ forloop.index0 | times: 0.07 }}s">
          <a href="{{ product.url }}" class="tsq-product-card__image-wrap" tabindex="-1" aria-hidden="true">
            {% if product.featured_image %}
              <img
                class="tsq-product-card__image"
                src="{{ product.featured_image | image_url: width: 500 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="500"
                height="500"
              >
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--tsq-mocha);font-family:var(--tsq-font-display);font-size:14px;background:var(--tsq-champagne);">No Image</div>
            {% endif %}
          </a>
          <div class="tsq-product-card__details">
            {% assign vendor = product.vendor %}
            {% if vendor != blank %}
              <a href="{{ routes.collections_url }}/{{ vendor | handleize }}" class="tsq-product-card__brand">{{ vendor }}</a>
            {% endif %}
            <a href="{{ product.url }}" class="tsq-product-card__title">{{ product.title }}</a>
            <div class="tsq-product-card__stars" aria-label="5 stars">
              ★★★★★
            </div>
            <div class="tsq-product-card__price">
              {{ product.price | money }}
            </div>
            <a href="{{ product.url }}?add-to-cart=1" class="tsq-product-card__btn" aria-label="Add {{ product.title | escape }} to cart">
              Add to Cart
            </a>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_view_all %}
      <div style="text-align:center; margin-top:48px;">
        <a href="{{ routes.collections_url }}/{{ section.settings.collection | default: 'all' }}" class="tsq-btn tsq-btn--secondary">
          {{ section.settings.view_all_label | default: 'VIEW ALL FRAGRANCES' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "TSQ Featured Products",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Our Selection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Featured Fragrances"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "min": 4,
      "max": 12,
      "step": 4,
      "label": "Number of products",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all button label",
      "default": "VIEW ALL FRAGRANCES"
    }
  ],
  "presets": [
    {
      "name": "TSQ Featured Products"
    }
  ]
}
{% endschema %}
