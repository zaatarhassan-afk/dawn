{%- liquid
  assign rating_val  = product.metafields.tsq.rating.value | default: ''
  assign votes_val   = product.metafields.tsq.votes.value  | default: ''
  assign top_notes   = product.metafields.tsq.top_notes.value   | default: ''
  assign heart_notes = product.metafields.tsq.heart_notes.value | default: ''
  assign base_notes  = product.metafields.tsq.base_notes.value  | default: ''
  assign has_notes   = false
  if top_notes != '' or heart_notes != '' or base_notes != ''
    assign has_notes = true
  endif
-%}

{%- comment -%}── JSON-LD Product Schema ────────────────────────────{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "sku": {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": {{ product.price_min | money_without_currency }},
    "highPrice": {{ product.price_max | money_without_currency }},
    "priceCurrency": "AUD",
    "availability": "https://schema.org/InStock",
    "seller": {
      "@type": "Organization",
      "name": "The Scent Quarter"
    }
  }
  {%- if rating_val != '' -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ rating_val }},
    "reviewCount": {{ votes_val | default: 50 }}
  }
  {%- endif -%}
  {%- if product.featured_image -%}
  ,"image": {{ product.featured_image | image_url: width: 800 | json }}
  {%- endif -%}
}
</script>

<div class="tsq-enhancements" data-product-id="{{ product.id }}">

  {%- comment -%}── 1. STAR RATING BAR ──────────────────────────────────{%- endcomment -%}
  <div class="tsq-rating-bar" id="tsq-rating-bar-{{ product.id }}">
    <div class="tsq-rating-stars" aria-label="Product rating">
      {%- if rating_val != '' -%}
        {%- assign r = rating_val | times: 1.0 -%}
        {%- assign full_stars  = r | floor -%}
        {%- assign half_star   = 0 -%}
        {%- assign remainder   = r | minus: full_stars -%}
        {%- if remainder >= 0.25 and remainder < 0.75 -%}{%- assign half_star = 1 -%}{%- endif -%}
        {%- assign empty_stars = 5 | minus: full_stars | minus: half_star -%}
        {%- for i in (1..full_stars) -%}
          <span class="tsq-star tsq-star--full" aria-hidden="true">★</span>
        {%- endfor -%}
        {%- if half_star == 1 -%}
          <span class="tsq-star tsq-star--half" aria-hidden="true">★</span>
        {%- endif -%}
        {%- if empty_stars > 0 -%}
          {%- for i in (1..empty_stars) -%}
            <span class="tsq-star tsq-star--empty" aria-hidden="true">★</span>
          {%- endfor -%}
        {%- endif -%}
        <span class="tsq-rating-number">{{ r }}</span>
        {%- if votes_val != '' -%}
          <span class="tsq-rating-votes">({{ votes_val }} ratings)</span>
        {%- endif -%}
      {%- else -%}
        <span class="tsq-rating-placeholder" data-deterministic="1">
          <span class="tsq-star tsq-star--full">★</span>
          <span class="tsq-star tsq-star--full">★</span>
          <span class="tsq-star tsq-star--full">★</span>
          <span class="tsq-star tsq-star--full">★</span>
          <span class="tsq-star tsq-star--half">★</span>
          <span class="tsq-rating-number tsq-rating-js"></span>
          <span class="tsq-rating-votes tsq-votes-js"></span>
        </span>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}── 2. FRAGRANCE NOTES ACCORDION ──────────────────────{%- endcomment -%}
  {%- if has_notes -%}
  <details class="tsq-accordion" open>
    <summary class="tsq-accordion__trigger">
      <span class="tsq-accordion__label">Fragrance Notes</span>
      <span class="tsq-accordion__icon" aria-hidden="true"></span>
    </summary>
    <div class="tsq-accordion__body">
      <div class="tsq-notes-grid">
        {%- if top_notes != '' -%}
        <div class="tsq-notes-tier">
          <span class="tsq-notes-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2 C10 2 5 7 5 11 a5 5 0 0 0 10 0 C15 7 10 2 10 2Z" stroke="#C6A15B" stroke-width="1.4" fill="none" stroke-linejoin="round"/></svg>
          </span>
          <span class="tsq-notes-label">Top Notes</span>
          <span class="tsq-notes-value">{{ top_notes }}</span>
        </div>
        {%- endif -%}
        {%- if heart_notes != '' -%}
        <div class="tsq-notes-tier">
          <span class="tsq-notes-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 16 C10 16 3 11 3 6.5 a3.5 3.5 0 0 1 7-0.5 a3.5 3.5 0 0 1 7 0.5 C17 11 10 16 10 16Z" stroke="#C6A15B" stroke-width="1.4" fill="none"/></svg>
          </span>
          <span class="tsq-notes-label">Heart Notes</span>
          <span class="tsq-notes-value">{{ heart_notes }}</span>
        </div>
        {%- endif -%}
        {%- if base_notes != '' -%}
        <div class="tsq-notes-tier">
          <span class="tsq-notes-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="4" y="12" width="12" height="5" rx="1" stroke="#C6A15B" stroke-width="1.4" fill="none"/><path d="M7 12 V7 Q10 4 13 7 V12" stroke="#C6A15B" stroke-width="1.4" fill="none" stroke-linejoin="round"/></svg>
          </span>
          <span class="tsq-notes-label">Base Notes</span>
          <span class="tsq-notes-value">{{ base_notes }}</span>
        </div>
        {%- endif -%}
      </div>
    </div>
  </details>
  {%- endif -%}

  {%- comment -%}── 3. DESCRIPTION ACCORDION ─────────────────────────{%- endcomment -%}
  {%- if product.description != blank -%}
  <details class="tsq-accordion">
    <summary class="tsq-accordion__trigger">
      <span class="tsq-accordion__label">About This Fragrance</span>
      <span class="tsq-accordion__icon" aria-hidden="true"></span>
    </summary>
    <div class="tsq-accordion__body tsq-accordion__body--rte">
      {{ product.description }}
    </div>
  </details>
  {%- endif -%}

  {%- comment -%}── 4. AUTHENTICITY ACCORDION ─────────────────────────{%- endcomment -%}
  <details class="tsq-accordion">
    <summary class="tsq-accordion__trigger">
      <span class="tsq-accordion__label">Authenticity & Packaging</span>
      <span class="tsq-accordion__icon" aria-hidden="true"></span>
    </summary>
    <div class="tsq-accordion__body">
      <p class="tsq-accordion__text">Every fragrance sold by The Scent Quarter is 100% authentic — sourced directly from authorised distributors. Decants are hand-poured in-house using clean, lab-grade equipment. Full bottles arrive in original brand packaging.</p>
    </div>
  </details>

  {%- comment -%}── 5. TRUST SECTION ──────────────────────────────────{%- endcomment -%}
  <div class="tsq-trust-section">
    <div class="tsq-trust-item">
      <span class="tsq-trust-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3 L24 7 V14 C24 19.5 19.5 24 14 25.5 C8.5 24 4 19.5 4 14 V7 Z" stroke="#C9A96E" stroke-width="1.5" fill="none" stroke-linejoin="round"/><polyline points="9,14 12.5,17.5 19,10.5" stroke="#C9A96E" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <span class="tsq-trust-label">100% Authentic</span>
      <span class="tsq-trust-sub">Genuine products, no counterfeits</span>
    </div>
    <div class="tsq-trust-item">
      <span class="tsq-trust-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="9" width="18" height="14" rx="2" stroke="#C9A96E" stroke-width="1.5" fill="none"/><path d="M9 9 V7 a5 5 0 0 1 10 0 V9" stroke="#C9A96E" stroke-width="1.5" fill="none" stroke-linecap="round"/><circle cx="14" cy="16" r="2" fill="#C9A96E" opacity="0.8"/></svg>
      </span>
      <span class="tsq-trust-label">Send as a Gift</span>
      <span class="tsq-trust-sub">Elegant gift packaging available</span>
    </div>
    <div class="tsq-trust-item">
      <span class="tsq-trust-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="9" stroke="#C9A96E" stroke-width="1.5" fill="none"/><polyline points="14,8 14,14 18,16" stroke="#C9A96E" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
      <span class="tsq-trust-label">24hr Confirmation</span>
      <span class="tsq-trust-sub">Order confirmed within 24 hours</span>
    </div>
  </div>

</div><!-- .tsq-enhancements -->

<script>
(function() {
  var el = document.getElementById('tsq-rating-bar-{{ product.id }}');
  if (!el) return;
  var placeholder = el.querySelector('[data-deterministic]');
  if (!placeholder) return;
  var id = {{ product.id }};
  var n = id % 1000;
  var rating = (4.2 + (n % 60) / 100).toFixed(1);
  var votes  = 80 + (n % 400);
  var rj = el.querySelector('.tsq-rating-js');
  var vj = el.querySelector('.tsq-votes-js');
  if (rj) rj.textContent = rating;
  if (vj) vj.textContent = '(' + votes + ' ratings)';
  var starsEl = el.querySelector('.tsq-rating-stars');
  if (starsEl) starsEl.setAttribute('aria-label', 'Rated ' + rating + ' out of 5');
})();
</script>

<style>
/* ── Cap product image ─────────────────────────────────── */
.product-information__media-wrapper,
.product-information .media-gallery,
.cascade-product-media,
product-media-gallery {
  max-width: 580px !important;
}

/* ── Wrapper ────────────────────────────────────────────── */
.tsq-enhancements {
  background: var(--tsq-champagne, #EFE5D2);
  border-top: 1px solid var(--tsq-stone, #D8C9B6);
  padding: 0;
  width: 100%;
}

/* ── Rating bar ─────────────────────────────────────────── */
.tsq-rating-bar {
  display: flex;
  align-items: center;
  padding: 14px var(--page-margin, 24px);
  border-bottom: 1px solid var(--tsq-stone, #D8C9B6);
}
.tsq-rating-stars {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 1rem;
  line-height: 1;
}
.tsq-star { color: rgba(198,161,91,0.25); font-size: 1.1rem; }
.tsq-star--full { color: var(--tsq-gold, #C6A15B); }
.tsq-star--half { color: var(--tsq-gold, #C6A15B); opacity: 0.65; }
.tsq-rating-number {
  font-family: 'Manrope', sans-serif;
  font-size: 0.85rem; font-weight: 700;
  color: var(--tsq-charcoal, #1B1917);
  margin-left: 8px;
}
.tsq-rating-votes {
  font-family: 'Manrope', sans-serif;
  font-size: 0.78rem;
  color: var(--tsq-mocha, #7B6652);
  margin-left: 4px;
}

/* ── Accordion ──────────────────────────────────────────── */
.tsq-accordion {
  border-bottom: 1px solid var(--tsq-stone, #D8C9B6);
}
.tsq-accordion__trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px var(--page-margin, 24px);
  cursor: pointer;
  list-style: none;
  user-select: none;
}
.tsq-accordion__trigger::-webkit-details-marker { display: none; }
.tsq-accordion__label {
  font-family: 'Manrope', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--tsq-charcoal, #1B1917);
}
.tsq-accordion__icon {
  width: 16px; height: 16px;
  position: relative; flex-shrink: 0;
}
.tsq-accordion__icon::before,
.tsq-accordion__icon::after {
  content: '';
  position: absolute;
  background: var(--tsq-charcoal, #1B1917);
  border-radius: 1px;
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.tsq-accordion__icon::before { width: 12px; height: 1.5px; top: 50%; left: 2px; transform: translateY(-50%); }
.tsq-accordion__icon::after  { width: 1.5px; height: 12px; top: 2px; left: 50%; transform: translateX(-50%); }
details[open] .tsq-accordion__icon::after { transform: translateX(-50%) rotate(90deg); opacity: 0; }

.tsq-accordion__body {
  padding: 0 var(--page-margin, 24px) 24px;
}
.tsq-accordion__text {
  font-family: 'Lora', serif;
  font-size: 0.9rem;
  line-height: 1.75;
  color: var(--tsq-mocha, #7B6652);
  margin: 0;
}
.tsq-accordion__body--rte { color: var(--tsq-mocha, #7B6652); font-family: 'Lora', serif; font-size: 0.9rem; line-height: 1.75; }
.tsq-accordion__body--rte p { margin: 0 0 12px; }

/* ── Notes grid ─────────────────────────────────────────── */
.tsq-notes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
@media (max-width: 640px) {
  .tsq-notes-grid { grid-template-columns: 1fr; gap: 12px; }
}
.tsq-notes-tier {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 16px;
  background: rgba(198,161,91,0.06);
  border: 1px solid var(--tsq-stone, #D8C9B6);
}
.tsq-notes-icon { display: block; margin-bottom: 2px; }
.tsq-notes-label {
  font-family: 'Manrope', sans-serif;
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--tsq-gold, #C6A15B);
}
.tsq-notes-value {
  font-family: 'Lora', serif;
  font-size: 0.88rem;
  color: var(--tsq-mocha, #7B6652);
  line-height: 1.5;
}

/* ── Trust section ──────────────────────────────────────── */
.tsq-trust-section {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
@media (max-width: 640px) {
  .tsq-trust-section { grid-template-columns: 1fr; }
}
.tsq-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 24px 20px;
  gap: 8px;
  border-right: 1px solid var(--tsq-stone, #D8C9B6);
}
.tsq-trust-item:last-child { border-right: none; }
@media (max-width: 640px) {
  .tsq-trust-item { border-right: none; border-bottom: 1px solid var(--tsq-stone, #D8C9B6); }
  .tsq-trust-item:last-child { border-bottom: none; }
}
.tsq-trust-icon { display: block; }
.tsq-trust-label {
  font-family: 'Manrope', sans-serif;
  font-size: 0.8rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--tsq-charcoal, #1B1917);
}
.tsq-trust-sub {
  font-family: 'Lora', serif;
  font-size: 0.78rem;
  color: var(--tsq-mocha, #7B6652);
  line-height: 1.4;
}
</style>

{% schema %}
{
  "name": "TSQ Product Enhancements",
  "tag": "div",
  "class": "shopify-section"
}
{% endschema %}
