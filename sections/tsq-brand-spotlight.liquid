<div class="shopify-section" style="background:var(--tsq-nearblack,#1A1410);padding:90px 0;border-top:1px solid rgba(201,169,110,0.12);">
  <div style="text-align:center;margin-bottom:48px;padding:0 20px;">
    <span class="tsq-eyebrow">The Houses</span>
    <div class="tsq-divider"></div>
    <h2>Our Fragrance Houses</h2>
    <p style="color:rgba(250,247,242,0.6);max-width:520px;margin:0 auto;font-size:15px;">
      Curated from the finest Arabian perfumers. Authentic, exceptional, available as decants from $15.
    </p>
  </div>

  <div class="tsq-brands-grid">
    {%- assign brand_handles = "lattafa,afnan,rasasi,armaf,gissah,swiss-arabian,reef,iibaar,maison-asrar,milestone" | split: "," -%}
    {%- for handle in brand_handles -%}
      {%- assign col = collections[handle] -%}
      {%- if col and col.products.size > 0 -%}
        <a href="{{ col.url }}" class="tsq-brand-card">
          {%- if col.products.first.featured_image -%}
            <img src="{{ col.products.first.featured_image | image_url: width: 600 }}"
                 alt="{{ col.title }}" class="tsq-brand-card__img" loading="lazy">
          {%- endif -%}
          <div class="tsq-brand-card__body">
            <p class="tsq-brand-card__name">{{ col.title }}</p>
            <p class="tsq-brand-card__count">{{ col.products_count }} fragrance{% if col.products_count != 1 %}s{% endif %}</p>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "TSQ Brand Spotlight",
  "tag": "div",
  "class": "shopify-section"
}
{% endschema %}
