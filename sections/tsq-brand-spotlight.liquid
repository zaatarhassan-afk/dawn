<div class="shopify-section tsq-section tsq-section--champagne">
  <div class="tsq-section__inner">
    <span class="tsq-eyebrow">The Houses</span>
    <div class="tsq-divider"></div>
    <h2 class="tsq-section-title">Our Fragrance Houses</h2>
    <p style="font-family:var(--tsq-b);font-size:15px;color:var(--tsq-text-2);max-width:520px;margin:0 auto 48px;line-height:1.7;">
      Curated from the world's finest fragrance houses. Authentic, exceptional, available as decants from $15.
    </p>
  </div>

  <div class="tsq-brands-grid">
    {%- assign brand_handles = "afnan,ahmed-al-maghribi,armaf,arabian-oud,emir,fragrance-world,gissah,ibraq,khadlaj,lattafa,maison-alhambra,paris-corner,rasasi,rayhaan,reef,swiss-arabian" | split: "," -%}
    {%- for handle in brand_handles -%}
      {%- assign col = collections[handle] -%}
      {%- if col -%}
        <a href="{{ col.url }}" class="tsq-brand-card">
          {%- if col.image -%}
            <img src="{{ col.image | image_url: width: 600 }}" alt="{{ col.title }}" class="tsq-brand-card__img" loading="lazy">
          {%- elsif col.products.first.featured_image -%}
            <img src="{{ col.products.first.featured_image | image_url: width: 600 }}" alt="{{ col.title }}" class="tsq-brand-card__img" loading="lazy">
          {%- endif -%}
          <div class="tsq-brand-card__body">
            <p class="tsq-brand-card__name">{{ col.title }}</p>
            <p class="tsq-brand-card__count">{{ col.products_count }} fragrance{% if col.products_count != 1 %}s{% endif %}</p>
          </div>
        </a>
      {%- else -%}
        <a href="/collections/{{ handle }}" class="tsq-brand-card">
          <div class="tsq-brand-card__body">
            <p class="tsq-brand-card__name">{{ handle | replace: '-', ' ' | capitalize }}</p>
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "TSQ Brand Spotlight",
  "tag": "div",
  "class": "shopify-section"
}
{% endschema %}
