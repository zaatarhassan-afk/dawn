<section class="tsq-hero">
  <div class="tsq-hero__content">
    <p class="tsq-hero__eyebrow">Authentic · Premium · Australia</p>
    <h1>Discover Your<br>Signature Scent</h1>
    <p>Premium fragrances from the world's finest houses — curated for the discerning nose. Full bottles and decants from $15.</p>
    <div class="tsq-hero__ctas tsq-hero__buttons">
      <a href="/collections/all" class="tsq-btn tsq-btn--gold">Shop Full Bottles</a>
      <a href="/collections/all-decants" class="tsq-btn tsq-btn--ghost-light">Browse Decants</a>
    </div>
  </div>
</section>

<style>
.tsq-btn--gold {
  display: inline-block;
  padding: 14px 36px;
  background: var(--tsq-gold, #C6A15B);
  color: var(--tsq-obsidian, #090807) !important;
  font-family: 'Manrope', sans-serif;
  font-size: 11px; letter-spacing: 0.18em;
  text-transform: uppercase; font-weight: 600;
  text-decoration: none !important;
  border: 1px solid transparent;
  transition: background 0.2s ease, color 0.2s ease;
}
.tsq-btn--gold:hover {
  background: var(--tsq-amber, #A86F3C);
  color: #fff !important;
}
.tsq-btn--ghost-light {
  display: inline-block;
  padding: 14px 36px;
  background: transparent;
  color: var(--tsq-text-d1, rgba(250,247,242,0.93)) !important;
  font-family: 'Manrope', sans-serif;
  font-size: 11px; letter-spacing: 0.18em;
  text-transform: uppercase; font-weight: 500;
  text-decoration: none !important;
  border: 1px solid rgba(250,247,242,0.35);
  transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
}
.tsq-btn--ghost-light:hover {
  border-color: rgba(250,247,242,0.7);
  color: #fff !important;
  background: rgba(250,247,242,0.08);
}
</style>

{% schema %}
{
  "name": "TSQ Hero",
  "tag": "div",
  "class": "shopify-section",
  "presets": [{ "name": "TSQ Hero" }]
}
{% endschema %}
