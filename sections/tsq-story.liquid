<div class="tsq-story">
  {% if section.settings.image != blank %}
    <img src="{{ section.settings.image | image_url: width: 900 }}" alt="The Scent Quarter" class="tsq-story__image" loading="lazy">
  {% else %}
    <div style="background:linear-gradient(135deg,#1A1208,#0D0A05);display:flex;align-items:center;justify-content:center;min-height:400px;">
      <span style="font-family:var(--tsq-font-display);font-size:80px;opacity:0.12;color:#C9A96E;">SQ</span>
    </div>
  {% endif %}
  <div class="tsq-story__text">
    <p class="tsq-story__overline">Our Story</p>
    <h2 class="tsq-story__heading">{{ section.settings.heading | default: "We're obsessed with scent." }}</h2>
    <p class="tsq-story__body">{{ section.settings.body | default: "The finest Arabian and Middle Eastern fragrances have always been reserved for those willing to spend $200 on a full bottle. We think that's wrong. The Scent Quarter lets you explore the world's most compelling perfumery — one decant at a time." }}</p>
    <a href="{{ section.settings.cta_link | default: '/pages/about' }}" class="button button--secondary">{{ section.settings.cta_label | default: 'Our Story' }}</a>
  </div>
</div>

{% schema %}
{
  "name": "TSQ Story",
  "tag": "div",
  "class": "shopify-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "We're obsessed with scent." },
    { "type": "textarea", "id": "body", "label": "Body text" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Our Story" }
  ],
  "presets": [{ "name": "TSQ Story" }]
}
{% endschema %}
